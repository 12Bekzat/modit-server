# Use the real database hostname from your hosting provider.
# "postgres" works only when the backend and PostgreSQL run in the same Docker Compose network
# and the database service is named "postgres".
DB_URL=jdbc:postgresql://HOST:5432/DB_NAME
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME

APP_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
APP_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_BYTE_SECRET
APP_JWT_ISSUER=magazine-server
APP_JWT_ACCESS_TOKEN_TTL=PT12H

APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
APP_ADMIN_FULL_NAME=System Administrator
APP_ADMIN_PHONE=+70000000000
